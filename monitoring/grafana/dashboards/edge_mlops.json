{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "edge_mlops - Inference Monitoring",
  "tags": ["mlops", "edge", "raspberry-pi"],
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Predicciones totales",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "edge_predictions_total", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } } }
    },
    {
      "type": "stat",
      "title": "Errores de prediccion",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "edge_prediction_errors_total", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Tasa de predicciones (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{ "expr": "rate(edge_predictions_total[1m])", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Latencia p95 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(edge_prediction_latency_seconds_bucket[5m]))", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Ultimo valor predicho",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{ "expr": "edge_last_prediction_value", "refId": "A" }]
    }
  ]
}
